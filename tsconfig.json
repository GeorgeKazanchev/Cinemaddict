{
    "ts-node": {
        "compilerOptions": {
            "module": "CommonJS"
        }
    },
    "compilerOptions": {
        "outDir": "./src/main.js",
        "module": "ESNext",
        "target": "ESNext",
        "noImplicitAny": true,
        "moduleResolution": "Bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "allowJs": true,
        "removeComments": true,
        "sourceMap": true,
        "strict": true
    }
}
